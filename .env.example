# Worker concurrency per instance
CONCURRENCY=5

# Delay between requests (ms)
DELAY_MS=500

# Per-email timeout (ms)
TIMEOUT_MS=30000

# Job poll interval (ms)
POLL_INTERVAL=5000

# SOCKS5 proxy pool (comma-separated, optional)
# PROXIES=socks5://user:pass@host1:1080,socks5://user:pass@host2:1080
PROXIES=

# Number of worker replicas (used with docker-compose up --scale worker=N)
WORKER_REPLICAS=1

# API URL for frontend (set to your public backend URL when deploying)
VITE_API_URL=http://localhost:3001
